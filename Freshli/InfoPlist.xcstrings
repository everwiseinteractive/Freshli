    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli uses your camera to scan barcodes and receipts for quick item entry."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli usa tu c\u00e1mara para escanear c\u00f3digos de barras y recibos para registrar productos r\u00e1pidamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli utilise votre cam\u00e9ra pour scanner les codes-barres et les re\u00e7us afin d\u2019ajouter rapidement vos produits."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli verwendet deine Kamera, um Barcodes und Kassenbons zu scannen und Artikel schnell hinzuzuf\u00fcgen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Freshli usa sua c\u00e2mera para escanear c\u00f3digos de barras e recibos para cadastrar itens rapidamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli\u306f\u30ab\u30e1\u30e9\u3092\u4f7f\u7528\u3057\u3066\u30d0\u30fc\u30b3\u30fc\u30c9\u3084\u30ec\u30b7\u30fc\u30c8\u3092\u30b9\u30ad\u30e3\u30f3\u3057\u3001\u98df\u54c1\u3092\u7d20\u65e9\u304f\u767b\u9332\u3057\u307e\u3059\u3002"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli uses your location to show nearby community food listings and set pickup locations."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli usa tu ubicaci\u00f3n para mostrar alimentos compartidos cerca de ti y establecer puntos de recogida."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli utilise votre position pour afficher les annonces alimentaires proches et d\u00e9finir les lieux de retrait."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli verwendet deinen Standort, um Lebensmittelangebote in der N\u00e4he anzuzeigen und Abholorte festzulegen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Freshli usa sua localiza\u00e7\u00e3o para mostrar an\u00fancios de alimentos pr\u00f3ximos e definir locais de retirada."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli\u306f\u4f4d\u7f6e\u60c5\u5831\u3092\u4f7f\u7528\u3057\u3066\u8fd1\u304f\u306e\u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u98df\u54c1\u60c5\u5831\u3092\u8868\u793a\u3057\u3001\u53d7\u3051\u53d6\u308a\u5834\u6240\u3092\u8a2d\u5b9a\u3057\u307e\u3059\u3002"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli accesses your photos to add images to pantry items and community listings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli accede a tus fotos para agregar im\u00e1genes a los productos de tu despensa y a los anuncios comunitarios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli acc\u00e8de \u00e0 vos photos pour ajouter des images \u00e0 vos produits et annonces communautaires."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli greift auf deine Fotos zu, um Bilder zu Vorratsartikeln und Community-Anzeigen hinzuzuf\u00fcgen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Freshli acessa suas fotos para adicionar imagens aos itens da despensa e an\u00fancios da comunidade."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli\u306f\u5199\u771f\u306b\u30a2\u30af\u30bb\u30b9\u3057\u3066\u3001\u98df\u54c1\u3084\u30b3\u30df\u30e5\u30cb\u30c6\u30a3\u51fa\u54c1\u306b\u753b\u50cf\u3092\u8ffd\u52a0\u3057\u307e\u3059\u3002"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli saves shared recipe images and impact cards to your photo library."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli guarda im\u00e1genes de recetas compartidas y tarjetas de impacto en tu biblioteca de fotos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli enregistre les images de recettes partag\u00e9es et les cartes d\u2019impact dans votre phototh\u00e8que."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli speichert geteilte Rezeptbilder und Impact-Karten in deiner Fotomediathek."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Freshli salva imagens de receitas compartilhadas e cart\u00f5es de impacto na sua biblioteca de fotos."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Freshli\u306f\u5171\u6709\u30ec\u30b7\u30d4\u753b\u50cf\u3084\u30a4\u30f3\u30d1\u30af\u30c8\u30ab\u30fc\u30c9\u3092\u5199\u771f\u30e9\u30a4\u30d6\u30e9\u30ea\u306b\u4fdd\u5b58\u3057\u307e\u3059\u3002"
          }
        }
      }
    }
  },
  "version" : "1.0"
}